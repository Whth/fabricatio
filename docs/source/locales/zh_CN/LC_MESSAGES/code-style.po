#: ../../source/code-style.rst:2
msgid "Code Style Guide"
msgstr "代码风格指南"

#: ../../source/code-style.rst:4
msgid ""
"This document outlines the code style conventions used in the Fabricatio "
"project."
msgstr "本文档概述了 Fabricatio 项目中使用的代码风格规范。"

#: ../../source/code-style.rst:13
msgid "Rust Conventions"
msgstr "Rust 规范"

#: ../../source/code-style.rst:16
msgid "Edition and Build Configuration"
msgstr "版本与构建配置"

#: ../../source/code-style.rst:18
msgid "**Edition 2024**: All Rust crates use ``edition = \"2024\"``"
msgstr "**Edition 2024**：所有 Rust crate 使用 ``edition = \"2024\"``"

#: ../../source/code-style.rst:27
msgid "**CDYLIB for PyO3**: Python-bound crates use ``crate-type = [\"cdylib\"]``"
msgstr "**PyO3 的 CDYLIB**：与 Python 绑定的 crate 使用 ``crate-type = [\"cdylib\"]``"

#: ../../source/code-style.rst:35 ../../source/code-style.rst:270
msgid "Naming Conventions"
msgstr "命名规范"

#: ../../source/code-style.rst:37 ../../source/code-style.rst:279
msgid "**Functions and variables**: ``snake_case``"
msgstr "**函数和变量**：``snake_case``"

#: ../../source/code-style.rst:44
msgid "**Types and structs**: ``PascalCase``"
msgstr "**类型和结构体**：``PascalCase``"

#: ../../source/code-style.rst:51
msgid "**Constants**: ``SCREAMING_SNAKE_CASE``"
msgstr "**常量**：``SCREAMING_SNAKE_CASE``"

#: ../../source/code-style.rst:59
msgid "Module Organization"
msgstr "模块组织"

#: ../../source/code-style.rst:61
msgid "Use ``pub mod`` for public modules, ``mod`` for private"
msgstr "公共模块使用 ``pub mod``，私有模块使用 ``mod``"

#: ../../source/code-style.rst:69
msgid "Module files: Use ``mod.rs`` for submodules or individual ``.rs`` files"
msgstr "模块文件：子模块使用 ``mod.rs``，或使用单独的 ``.rs`` 文件"

#: ../../source/code-style.rst:79
msgid "Error Handling"
msgstr "错误处理"

#: ../../source/code-style.rst:81
msgid "**Use ``thiserror``** for creating error enums with ``#[derive(Error)]``"
msgstr "**使用 ``thiserror``** 通过 ``#[derive(Error)]`` 创建错误枚举"

#: ../../source/code-style.rst:98
msgid ""
"**Error variants** should have human-readable messages using "
"``#[error(...)]``"
msgstr "**错误变体** 应使用 ``#[error(...)]`` 提供人类可读的错误信息"

#: ../../source/code-style.rst:101
msgid "Doc Comments"
msgstr "文档注释"

#: ../../source/code-style.rst:103
msgid "**Crate-level**: Use ``//!`` at the top of lib.rs"
msgstr "**Crate 级别**：在 lib.rs 顶部使用 ``//!``"

#: ../../source/code-style.rst:113
msgid "**Function-level**: Use ``///`` with markdown formatting"
msgstr "**函数级别**：使用 ``///`` 并采用 Markdown 格式"

#: ../../source/code-style.rst:123
msgid "PyO3 Patterns"
msgstr "PyO3 模式"

#: ../../source/code-style.rst:125
msgid "**PyModule**: ``#[pymodule]`` with `` Bound<'_, PyModule>`` parameter"
msgstr "**PyModule**：``#[pymodule]`` 配合 ``Bound<'_, PyModule>`` 参数"

#: ../../source/code-style.rst:134
msgid ""
"**PyClass**: ``#[pyclass]`` with optional ``#[cfg_attr(feature = "
"\"stubgen\", ...)]``"
msgstr ""
"**PyClass**：``#[pyclass]`` 配合可选的 ``#[cfg_attr(feature = "
"\"stubgen\", ...)]``"

#: ../../source/code-style.rst:143
msgid ""
"**PyMethods**: ``#[pymethods]`` with ``#[cfg_attr(...)]`` for conditional"
" stub generation"
msgstr ""
"**PyMethods**：``#[pymethods]`` 配合 ``#[cfg_attr(...)]`` 用于条件性"
"存根生成"

#: ../../source/code-style.rst:154 ../../source/code-style.rst:251
msgid "Async Patterns"
msgstr "异步模式"

#: ../../source/code-style.rst:156
msgid "**Use ``async-trait``** for async methods in traits"
msgstr "**使用 ``async-trait``** 在 trait 中定义异步方法"

#: ../../source/code-style.rst:167
msgid "**Let chains** for conditional await"
msgstr "**Let 链** 用于条件性 await"

#: ../../source/code-style.rst:177
msgid "**Tokio** for async runtime with multi-thread features"
msgstr "**Tokio** 用于多线程异步运行时"

#: ../../source/code-style.rst:184
msgid "Traits and Generics"
msgstr "Trait 与泛型"

#: ../../source/code-style.rst:186
msgid "**Generic bounds** use ``?Sized`` when appropriate"
msgstr "**泛型约束** 在适当时使用 ``?Sized``"

#: ../../source/code-style.rst:194
msgid "**Builder pattern** with ``mut self`` and ``-> Self``"
msgstr "**建造者模式** 使用 ``mut self`` 和 ``-> Self``"

#: ../../source/code-style.rst:204
msgid "Feature Flags"
msgstr "Feature 标志"

#: ../../source/code-style.rst:206
msgid "Use ``#[cfg(feature = \"...\")]`` for optional functionality"
msgstr "使用 ``#[cfg(feature = \"...\")]`` 控制可选功能"

#: ../../source/code-style.rst:213
msgid "Define features in ``[features]`` section"
msgstr "在 ``[features]`` 部分定义 feature"

#: ../../source/code-style.rst:224
msgid "Python Conventions"
msgstr "Python 规范"

#: ../../source/code-style.rst:227
msgid "Type Hints"
msgstr "类型提示"

#: ../../source/code-style.rst:229
msgid ""
"**Full annotations** required (project uses ``Typing :: Typed`` "
"classifier)"
msgstr ""
"要求**完整的类型注解**（项目使用 ``Typing :: Typed`` "
"分类器）"

#: ../../source/code-style.rst:237
msgid "**Generic type aliases** using ``type`` statement"
msgstr "**泛型类型别名** 使用 ``type`` 语句"

#: ../../source/code-style.rst:244
msgid "**Self returns** for method chaining"
msgstr "**返回 Self** 用于方法链式调用"

#: ../../source/code-style.rst:253
msgid "**``async def``** for all async functions"
msgstr "**``async def``** 用于所有异步函数"

#: ../../source/code-style.rst:261
msgid "**Use asyncio primitives**: ``create_task``, ``Queue``, ``sleep``"
msgstr "**使用 asyncio 原语**：``create_task``、``Queue``、``sleep``"

#: ../../source/code-style.rst:272
msgid "**Classes**: ``PascalCase``"
msgstr "**类**：``PascalCase``"

#: ../../source/code-style.rst:286
msgid "**Private attributes**: ``_prefix``"
msgstr "**私有属性**：``_prefix``"

#: ../../source/code-style.rst:294
msgid "Docstring Style"
msgstr "文档字符串风格"

#: ../../source/code-style.rst:296
msgid ""
"**Google-style docstrings** (configured in ruff: ``convention = "
"\"google\"``)"
msgstr ""
"**Google 风格文档字符串** （在 ruff 中配置：``convention = "
"google"``）"

#: ../../source/code-style.rst:312
msgid "**Module-level docstrings** at top of file"
msgstr "**模块级文档字符串** 位于文件顶部"

#: ../../source/code-style.rst:327
msgid "Pydantic v2 Patterns"
msgstr "Pydantic v2 模式"

#: ../../source/code-style.rst:329
msgid "**``ConfigDict``** for model configuration"
msgstr "**``ConfigDict``** 用于模型配置"

#: ../../source/code-style.rst:335
msgid "**``Field``** for field definitions with docstrings as descriptions"
msgstr "**``Field``** 用于字段定义，文档字符串作为描述"

#: ../../source/code-style.rst:345
msgid "**``PrivateAttr``** for private fields"
msgstr "**``PrivateAttr``** 用于私有字段"

#: ../../source/code-style.rst:353
msgid "**Generic models** with ``[T]`` syntax"
msgstr "**泛型模型** 使用 ``[T]`` 语法"

#: ../../source/code-style.rst:361
msgid "Imports Organization"
msgstr "导入组织"

#: ../../source/code-style.rst:363
msgid "**Type checking blocks** for circular imports"
msgstr "**类型检查块** 用于处理循环导入"

#: ../../source/code-style.rst:372
msgid "**typing extensions** for modern Python versions"
msgstr "**typing extensions** 用于现代 Python 版本"

#: ../../source/code-style.rst:379
msgid "Decorators"
msgstr "装饰器"

#: ../../source/code-style.rst:381
msgid "**``@final``** from typing for preventing subclassing"
msgstr "**``@final``** 来自 typing 模块，用于防止子类化"

#: ../../source/code-style.rst:388
msgid "**Custom decorators** in ``decorators.py``"
msgstr "**自定义装饰器** 位于 ``decorators.py``"

#: ../../source/code-style.rst:400
msgid "Git Conventions"
msgstr "Git 规范"

#: ../../source/code-style.rst:403
msgid "Branch Naming"
msgstr "分支命名"

#: ../../source/code-style.rst:405
msgid "**Feature branches**: ``feat/<feature-name>``"
msgstr "**功能分支**：``feat/<feature-name>``"

#: ../../source/code-style.rst:411
msgid "**Bugfix branches**: ``fix/<bug-name>``"
msgstr "**修复分支**：``fix/<bug-name>``"

#: ../../source/code-style.rst:413
msgid "**Chore branches**: ``chore/<task-name>``"
msgstr "**维护分支**：``chore/<task-name>``"

